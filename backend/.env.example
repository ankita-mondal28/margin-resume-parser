# ---------------------------------------------------
# Copy this file to ".env" in the same folder and fill
# in your own values. Never commit the real ".env" file.
# ---------------------------------------------------

# Required: your Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Optional: which Groq-hosted model to use for parsing.
# openai/gpt-oss-120b is Groq's current production-tier general-purpose
# model (as of July 2026) and supports JSON mode. If Groq later deprecates
# it, check https://console.groq.com/docs/models for the current
# recommended replacement and update this value — no code changes needed.
GROQ_MODEL=openai/gpt-oss-120b

# Optional: comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: max upload size in megabytes
MAX_FILE_SIZE_MB=8

# Optional: how many parse requests a single IP can make per minute
RATE_LIMIT_PER_MINUTE=10
